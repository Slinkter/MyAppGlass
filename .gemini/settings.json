{
  "hooksConfig": {
    "enabled": true,
    "notifications": true
  },
  "mcp": {
    "allowed": [
      "next-devtools",
      "chakra-ui"
    ]
  },
  "mcpServers": {
    "next-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "next-devtools-mcp@latest"
      ]
    },
    "chakra-ui": {
      "command": "npx",
      "args": [
        "-y",
        "@chakra-ui/react-mcp@latest"
      ]
    }
  },
  "hooks": {
    "BeforeTool": [],
    "AfterTool": [],
    "PreCompress": [],
    "SessionStart": []
  }
}
