{
  "hooksConfig": {
    "enabled": true,
    "notifications": true
  },
  "mcp": {
    "allowed": [
      "next-devtools",
      "chakra-ui",
      "context-mode",
      "sql-pedagogo",
      "mermaid-master",
      "tailwind-aura",
      "ux-architect",
      "firebase-deploy",
      "github-manager",
      "ascii-logic",
      "react-fba-bot",
      "google-search",
      "system-commander"
    ]
  },
  "mcpServers": {
    "next-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "next-devtools-mcp@latest"
      ]
    },
    "chakra-ui": {
      "command": "npx",
      "args": [
        "-y",
        "@chakra-ui/react-mcp@latest"
      ]
    },
    "context-mode": {
      "command": "npx",
      "args": [
        "-y",
        "context-mode@latest"
      ]
    }
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "run_shell_command|read_file|read_many_files|grep_search|search_file_content|web_fetch|activate_skill|mcp__plugin_context-mode",
        "hooks": [
          {
            "type": "command",
            "command": "npx context-mode hook gemini-cli beforetool"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "npx context-mode hook gemini-cli aftertool"
          }
        ]
      }
    ],
    "PreCompress": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "npx context-mode hook gemini-cli precompress"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "npx context-mode hook gemini-cli sessionstart"
          }
        ]
      }
    ]
  }
}
