{
  "mcpServers": {
    "next-devtools": {
      "command": "/usr/local/bin/npx",
      "args": ["-y", "next-devtools-mcp@latest"],
      "env": {
        "PATH": "/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    },
    "chakra-ui": {
      "command": "/usr/local/bin/npx",
      "args": ["-y", "@chakra-ui/react-mcp"],
      "env": {
        "PATH": "/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    }
  }
}
