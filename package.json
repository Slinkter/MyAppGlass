{
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node optimize-images.mjs && next dev",
    "build": "node optimize-images.mjs && next build",
    "preview": "next start",
    "optimize": "node optimize-images.mjs",
    "lint": "eslint src/",
    "py": "pnpm run build && pnpm exec tsc --noEmit 2>&1 && python -m http.server 5000 --directory dist",
    "predeploy": "pnpm run build",
    "deploy": "gh-pages -d dist",
    "deploy:hosting": "pnpm run build && npx firebase-tools deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions",
    "clean": "pnpm dlx rimraf node_modules dist functions/node_modules",
    "analyze": "pnpm run build",
    "start": "next start"
  },
  "private": true,
  "name": "my-glass-app",
"devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "eslint": "^8.57.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.26",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.34.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/lora": "^5.2.8",
    "@fontsource/open-sans": "^5.2.7",
    "@fontsource/raleway": "^5.2.8",
    "@heroicons/react": "^2.2.0",
    "@react-google-maps/api": "^2.20.8",
    "firebase": "^12.12.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "web-vitals": "^5.2.0"
  }
}
